<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram id="todos-architecture" name="Todos Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Todos — architecture: one Google Sheet, three stateless clients" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Tool logic is written once (registerTools + sheet-core) and reused across a stdio server and a hosted HTTP connector; the sheet is the only source of truth." style="text;html=1;fontSize=12;fontColor=#666666;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="1100" height="20" as="geometry" />
        </mxCell>

        <!-- ===== Actors ===== -->
        <mxCell id="A1" value="Browser&#10;(end user)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="140" y="100" width="220" height="64" as="geometry" />
        </mxCell>
        <mxCell id="A2" value="claude.ai — custom connector&#10;(web, plus cloud &amp; scheduled routines)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="340" height="64" as="geometry" />
        </mxCell>
        <mxCell id="A3" value="Local coding agents&#10;Claude Code · Codex" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="100" width="290" height="64" as="geometry" />
        </mxCell>

        <!-- ===== Client 1: web SPA ===== -->
        <mxCell id="B1" value="apps/web — static SPA (React + Vite)&#10;&#10;• Google Identity token (drive.file, in-memory)&#10;• polls the sheet every 5s; optimistic writes&#10;• row-targeted mutations (locate by id)&#10;• Agent-connect panel: shares the sheet&#10;  with a service account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="210" width="300" height="200" as="geometry" />
        </mxCell>

        <!-- ===== Client 2: hosted MCP connector (container) ===== -->
        <mxCell id="B2" value="apps/web/api — hosted MCP connector (Vercel Functions)   ·   opt-in per deployment via 3 env vars" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;align=center;fontStyle=1;fontSize=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="210" width="480" height="440" as="geometry" />
        </mxCell>
        <mxCell id="B2a" value="GET · POST · DELETE  /api/mcp&#10;&#10;verifyToken → Google tokeninfo&#10;(checks drive.file scope + aud)&#10;builds a per-request McpServer&#10;RemoteSheetStore(callerToken)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;align=left;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="260" width="215" height="170" as="geometry" />
        </mxCell>
        <mxCell id="B2b" value="OAuth AS — proxies Google&#10;&#10;/oauth/register  (DCR)&#10;/oauth/authorize  (PKCE S256, seal state)&#10;/oauth/callback  (seal Google code)&#10;/oauth/token  (code exchange)&#10;/.well-known/*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;align=left;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="805" y="260" width="215" height="170" as="geometry" />
        </mxCell>
        <mxCell id="B2note" value="Stateless: no DB, no sessions, no stored user credentials.  client_id encodes its own redirect URIs; our auth codes are sealed AES-256-GCM blobs keyed from AUTH_SIGNING_SECRET." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;spacingTop=4;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="580" y="450" width="440" height="80" as="geometry" />
        </mxCell>

        <!-- ===== Client 3: stdio MCP server ===== -->
        <mxCell id="B3" value="packages/mcp-server — stdio server&#10;&#10;• MCP over stdin / stdout&#10;• auth: a Google service account&#10;  you share the sheet with&#10;• env: TODOS_SPREADSHEET_ID,&#10;  GOOGLE_APPLICATION_CREDENTIALS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="210" width="290" height="200" as="geometry" />
        </mxCell>

        <!-- ===== Shared: sheet-core library ===== -->
        <mxCell id="C" value="packages/sheet-core&#10;&#10;shared schema + validation&#10;(precise row/col errors)&#10;ordering (sort_order floats)&#10;ID generation&#10;&#10;no runtime deps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="470" width="230" height="190" as="geometry" />
        </mxCell>

        <!-- ===== Shared: registerTools ===== -->
        <mxCell id="D" value="registerTools(server, SheetStore)&#10;&#10;6 tools:  list · add · update · move · complete · delete&#10;every write re-locates its row by id (one-row writes; no bulk tools)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;fontSize=12;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="690" y="710" width="360" height="110" as="geometry" />
        </mxCell>

        <!-- ===== Google services ===== -->
        <mxCell id="G_OAuth" value="Google OAuth&#10;consent + token endpoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="900" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="G_tokeninfo" value="Google tokeninfo&#10;bearer verification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="810" y="900" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="G_Sheets" value="Google Sheets &amp; Drive REST API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1050" y="900" width="290" height="80" as="geometry" />
        </mxCell>

        <!-- ===== Source of truth ===== -->
        <mxCell id="Sheet" value="📊  Google Sheet in your Drive — THE SINGLE SOURCE OF TRUTH&#10;one &quot;Tasks&quot; tab · one row per task · drive.file scope · Sheets version history = undo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="1030" width="780" height="90" as="geometry" />
        </mxCell>

        <!-- ===== Legend ===== -->
        <mxCell id="legend" value="Legend&#10;&#10;blue = actors / agents&#10;green = web SPA &amp; the sheet&#10;orange = hosted connector (Vercel)&#10;purple = stdio server&#10;yellow = shared library / sealed state&#10;red = the shared 6-tool engine&#10;gray = external Google services&#10;&#10;solid arrow = request / data flow&#10;dashed arrow = uses / grants" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="710" width="330" height="230" as="geometry" />
        </mxCell>

        <!-- ===== Edges ===== -->
        <mxCell id="e1" value="loads static files" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="A1" target="B1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="MCP over HTTPS&#10;+ OAuth sign-in" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="A2" target="B2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="MCP over stdio" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="A3" target="B3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e4" value="registerTools" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="B2a" target="D">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="registerTools" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="B3" target="D">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e6" value="proxies consent&#10;&amp; code exchange" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="B2b" target="G_OAuth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="verify bearer token" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="B2a" target="G_tokeninfo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e8" value="SheetStore →&#10;caller token / service acct" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="D" target="G_Sheets">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="user OAuth token (drive.file)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="B1" target="G_Sheets">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" value="reads / writes rows" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontStyle=1;" edge="1" parent="1" source="G_Sheets" target="Sheet">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e11" value="uses" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=open;dashed=1;fontSize=10;" edge="1" parent="1" source="B1" target="C">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="uses" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=open;dashed=1;fontSize=10;" edge="1" parent="1" source="D" target="C">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" value="Agent-connect: shares sheet&#10;with the service account" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=open;dashed=1;fontSize=10;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="B1" target="B3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
