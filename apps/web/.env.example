# Google Cloud OAuth client ID (Web application type), used by Google
# Identity Services for the drive.file token model. Public by design — it
# is baked into the static build. See docs/SETUP.md.
VITE_GOOGLE_CLIENT_ID=

# Google Cloud API key, used only for the Google Picker (attach-existing-
# sheet flow). Restrict it to the Picker API in the Cloud console.
VITE_GOOGLE_API_KEY=

# --- Hosted MCP connector (optional, server-side only) ---------------------
# Not prefixed with VITE_ — never bundled into the client, not read by
# `vite dev`. These three are read only by the Vercel Functions in api/, and
# only there: if any is unset, every /api/* route responds 503 and the rest
# of the app is unaffected. Set them as Vercel project environment variables
# (not in this file) when you want claude.ai to be able to add
# https://<your-deployment>/api/mcp as a custom connector. See docs/SETUP.md.

# Client ID/secret of a *second*, "Web application"-type OAuth client in the
# same Google Cloud project as VITE_GOOGLE_CLIENT_ID above, with redirect URI
# https://<your-deployment>/api/oauth/callback.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 32+ bytes of random hex (e.g. `openssl rand -hex 32`), used to derive the
# AEAD keys that seal OAuth state/codes between redirects. Treat like any
# other secret; rotating it invalidates any in-flight sign-ins.
AUTH_SIGNING_SECRET=
